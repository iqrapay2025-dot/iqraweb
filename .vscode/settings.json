{
    "snyk.advanced.autoSelectOrganization": true,
    "css.validate": false,
    "less.validate": false,
    "scss.validate": false,
    "json.schemaDownload.enable": false,
    "css.customData": [
        {
            "version": "1.1",
            "atDirectives": [
                {
                    "name": "@theme",
                    "description": "Define theme values inline in Tailwind CSS v4",
                    "references": [
                        {
                            "name": "Tailwind CSS v4 Documentation",
                            "url": "https://tailwindcss.com/docs/v4-beta"
                        }
                    ]
                },
                {
                    "name": "@apply",
                    "description": "Apply utility classes within CSS rules",
                    "references": [
                        {
                            "name": "Tailwind CSS Documentation",
                            "url": "https://tailwindcss.com/docs/functions-and-directives#apply"
                        }
                    ]
                },
                {
                    "name": "@layer",
                    "description": "Define CSS layers",
                    "references": [
                        {
                            "name": "CSS Cascading and Inheritance Level 5",
                            "url": "https://www.w3.org/TR/css-cascade-5/#layering"
                        }
                    ]
                },
                {
                    "name": "@custom-variant",
                    "description": "Define custom CSS variants in Tailwind CSS v4",
                    "references": [
                        {
                            "name": "Tailwind CSS v4 Documentation",
                            "url": "https://tailwindcss.com/docs/v4-beta"
                        }
                    ]
                }
            ]
        }
    ]
}